{
  "service": {
    "host": "0.0.0.0",
    "port": 8090
  },
  "device": {
    "device_id": "polealpha-zero2w",
    "scene": "desk"
  },
  "backend": {
    "enabled": true,
    "base_url": "http://127.0.0.1:8000",
    "heartbeat_interval_sec": 15,
    "timeout_sec": 5
  },
  "onboarding": {
    "enabled": true,
    "hotspot_ssid": "EmotionPi-Setup",
    "hotspot_password": "emotionpi123",
    "hotspot_connection_name": "emotion-pi-onboarding",
    "wifi_interface": "wlan0",
    "state_file": "/var/lib/emotion-pi/onboarding_state.json"
  },
  "identity": {
    "enabled": false,
    "storage_dir": "/var/lib/emotion-pi/identity",
    "models_dir": "models/identity",
    "detector_model_path": "models/identity/face_detection_yunet_2023mar.onnx",
    "recognizer_model_path": "models/identity/face_recognition_sface_2021dec.onnx",
    "recognition_interval_ms": 750,
    "enrollment_min_samples": 8,
    "enrollment_target_samples": 10,
    "enrollment_max_samples": 12,
    "enrollment_sample_interval_ms": 700,
    "similarity_threshold": 0.78
  },
  "audio": {
    "enabled": true,
    "sample_rate": 16000,
    "channels": 1,
    "frame_ms": 20,
    "command": [
      "arecord",
      "-q",
      "-D",
      "default",
      "-f",
      "S16_LE",
      "-r",
      "16000",
      "-c",
      "1",
      "-t",
      "raw"
    ],
    "restart_backoff_sec": 2.0
  },
  "camera": {
    "enabled": false,
    "backend": "picamera2",
    "device_index": 0,
    "width": 320,
    "height": 240,
    "fps": 2
  },
  "hardware": {
    "driver": "gpio",
    "speaker_command": [
      "aplay",
      "-q"
    ],
    "status_led_gpio": 17,
    "pan_servo": {
      "enabled": true,
      "driver": "gpio",
      "gpio_pin": 12,
      "min_angle": 45,
      "max_angle": 135,
      "center_angle": 90,
      "pca9685_channel": null,
      "pulse_min_us": 500,
      "pulse_max_us": 2500,
      "release_after_move_sec": 0.18
    },
    "tilt_servo": {
      "enabled": true,
      "driver": "gpio",
      "gpio_pin": 13,
      "min_angle": 65,
      "max_angle": 165,
      "center_angle": 90,
      "pca9685_channel": null,
      "pulse_min_us": 500,
      "pulse_max_us": 2500,
      "release_after_move_sec": 0.18
    },
    "pca9685": {
      "enabled": false,
      "address": 64,
      "frequency": 50
    }
  },
  "buttons": {
    "enabled": true,
    "allow_system_power_commands": false,
    "power_toggle": {
      "enabled": true,
      "gpio_pin": 5,
      "pull_up": true,
      "hold_sec": 0.0,
      "bounce_time": 0.08
    },
    "shutdown": {
      "enabled": true,
      "gpio_pin": 6,
      "pull_up": true,
      "hold_sec": 0.0,
      "bounce_time": 0.08
    },
    "settings": {
      "enabled": true,
      "gpio_pin": 23,
      "pull_up": true,
      "hold_sec": 0.0,
      "bounce_time": 0.08
    }
  },
  "ui": {
    "default_page": "expression",
    "settings_auto_return_sec": 0
  }
}
