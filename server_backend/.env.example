# Copy this file to server_backend/.env and edit values for your server.

# Strongly recommended: replace with a long random secret.
AUTH_SECRET_KEY=replace-with-a-strong-random-secret
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SEC=900
REFRESH_TOKEN_EXPIRE_SEC=1209600

# Persistent SQLite path used by backend.
AUTH_DB_PATH=server_backend/data/auth.db

# CORS origins for web/mobile clients.
# Use "*" only for quick testing.
AUTH_CORS_ORIGINS=https://your-web-domain.com,http://your-server-ip:5173

# Uvicorn runtime options (used by run_server.py)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WEB_CONCURRENCY=1

# Optional demo account bootstrap.
# When both values are provided, run:
# python scripts/bootstrap_server_backend.py --create-demo-user
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=

# Optional model providers used by the Pi runtime / backend care APIs.
ARK_API_KEY=
DASHSCOPE_API_KEY=
