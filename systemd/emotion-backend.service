[Unit]
Description=Emotion Companion Remote Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/emotion-pi
WorkingDirectory=__PROJECT_ROOT__
ExecStart=__PROJECT_ROOT__/.venv/bin/python server_backend/run_server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
