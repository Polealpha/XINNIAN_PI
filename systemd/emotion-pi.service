[Unit]
Description=Emotion Companion Pi Runtime
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/emotion-pi
WorkingDirectory=__PROJECT_ROOT__
ExecStart=__PROJECT_ROOT__/.venv/bin/python -m pi_runtime.server --config config/pi_zero2w.json --engine-config config/engine_config.json
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
