{
  "name": "emoresonance---dual-robot-companion",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare:python-runtime": "python ../scripts/prepare_desktop_python_runtime.py --target \"vendor/python-site-packages\" --python-home-target \"vendor/python-runtime\" --requirements ../backend/requirements.txt",
    "prepare:openclaw-runtime": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ../scripts/prepare_desktop_openclaw_runtime.ps1 -Source ../../openclaw -Target ./vendor/openclaw-runtime",
    "prepare:desktop-runtime": "npm run prepare:python-runtime && npm run prepare:openclaw-runtime",
    "build:installer": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ../scripts/build_desktop_installer.ps1 -AppDir ./release/win-unpacked -OutputFile \"./release/EmoResonance Setup 0.0.1.exe\"",
    "verify:installer": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ../scripts/verify_desktop_installer.ps1 -ReleaseDir ./release",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:3001 && cross-env ELECTRON_DEV_URL=http://localhost:3001 electron electron/main.cjs\"",
    "electron:pack": "npm run prepare:desktop-runtime && vite build && electron-builder --dir",
    "electron:dist": "npm run prepare:desktop-runtime && vite build && electron-builder --dir && npm run build:installer && npm run verify:installer"
  },
  "dependencies": {
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.emoresonance.desktop",
    "productName": "EmoResonance",
    "compression": "normal",
    "icon": "assets/app-icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "assets/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/python-runtime",
        "to": "bridge-runtime/python",
        "filter": [
          "**/*",
          "!**/Doc/**",
          "!**/include/**",
          "!**/libs/**",
          "!**/Scripts/**",
          "!**/tcl/**",
          "!**/Lib/site-packages/**",
          "!**/Lib/test/**",
          "!**/Lib/__pycache__/**",
          "!**/Lib/idlelib/**",
          "!**/Lib/ensurepip/**"
        ]
      },
      {
        "from": "vendor/python-site-packages",
        "to": "bridge-runtime/python/Lib/site-packages"
      },
      {
        "from": "../scripts",
        "to": "bridge-runtime/scripts"
      },
      {
        "from": "../backend",
        "to": "bridge-runtime/backend"
      },
      {
        "from": "../engine",
        "to": "bridge-runtime/engine"
      },
      {
        "from": "../apps",
        "to": "bridge-runtime/apps"
      },
      {
        "from": "../config",
        "to": "bridge-runtime/config"
      },
      {
        "from": "../models",
        "to": "bridge-runtime/models",
        "filter": [
          "mediapipe/**",
          "ferplus/**",
          "vision/**"
        ]
      },
      {
        "from": "vendor/openclaw-runtime",
        "to": "openclaw"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/app-icon.ico"
    },
    "nsis": {
      "differentialPackage": false,
      "useZip": false,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/app-icon.ico",
      "uninstallerIcon": "assets/app-icon.ico",
      "installerHeader": "assets/installer-header.bmp",
      "installerSidebar": "assets/installer-sidebar.bmp",
      "uninstallerSidebar": "assets/installer-sidebar.bmp"
    }
  }
}
